---
export interface Props {
  title:        string;
  description:  string;
  canonical?:   string;
  lang?:        string;
  og?:          string;
  ogType?:      string;
  keywords?:    string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  noindex?:     boolean;
  schema?:      any;
  publishedAt?: string;
  modifiedAt?:  string;
  author?:      string;
}

const SITE = 'https://solananuts.com';
const DEFAULT_OG = `${SITE}/og-default.jpg`;

const {
  title,
  description,
  canonical,
  lang = 'es',
  og = DEFAULT_OG,
  ogType = 'website',
  keywords,
  breadcrumbs,
  noindex = false,
  schema,
  publishedAt,
  modifiedAt,
  author = 'Solana Nuts',
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const url = canonical ?? SITE + pathname;

// Build hreflang alt URLs
const altEn = pathname === '/' ? `${SITE}/en/` : `${SITE}/en${pathname}`;

// Base organization JSON-LD (always present)
const organizationLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness", "Farm"],
  "@id": `${SITE}/#organization`,
  "name": "Solana Nuts",
  "alternateName": ["Solana Nuts Bajo Aragón", "Almendras y Nueces Solana Nuts"],
  "url": SITE,
  "logo": {
    "@type": "ImageObject",
    "url": `${SITE}/logo.png`,
    "width": 512,
    "height": 512,
  },
  "image": `${SITE}/og-default.jpg`,
  "description": "Finca familiar de almendras y nueces en Fayón, Bajo Aragón. Almendra Soleta, Lauranne y Nuez Chandler — 100% naturales, secado al aire, directo del productor.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Finca Solana",
    "addressLocality": "Fayón",
    "addressRegion": "Zaragoza",
    "postalCode": "50793",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 41.2486,
    "longitude": 0.3478
  },
  "areaServed": [
    { "@type": "Country", "name": "España" },
    { "@type": "Country", "name": "Portugal" },
    { "@type": "Country", "name": "Francia" },
    { "@type": "Country", "name": "Alemania" },
    { "@type": "Country", "name": "Italia" },
    { "@type": "Country", "name": "Reino Unido" },
    { "@type": "Country", "name": "Países Bajos" },
    { "@type": "Country", "name": "Bélgica" },
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Suiza" }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": "info@solananuts.com",
    "availableLanguage": ["Spanish", "English"]
  },
  "sameAs": [
    "https://instagram.com/solananuts",
    "https://t.me/solananuts"
  ],
  "knowsAbout": [
    "Almendra Soleta",
    "Almendra Lauranne",
    "Nuez Chandler",
    "Frutos secos naturales",
    "Agricultura familiar",
    "Bajo Aragón",
    "Cosecha a mano",
    "Secado al aire",
    "Envase reutilizable"
  ],
  "slogan": "Tierra, sol y alma",
  "foundingLocation": {
    "@type": "Place",
    "name": "Fayón, Bajo Aragón, España"
  }
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE}/#website`,
  "url": SITE,
  "name": "Solana Nuts",
  "description": "Almendras y nueces naturales del Bajo Aragón — directo del productor.",
  "publisher": { "@id": `${SITE}/#organization` },
  "inLanguage": ["es-ES", "en"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${SITE}/?s={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const breadcrumbLd = breadcrumbs && breadcrumbs.length ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": b.name,
    "item": b.url.startsWith('http') ? b.url : SITE + b.url,
  }))
} : null;
---
<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta http-equiv="x-ua-compatible" content="IE=edge"/>
  <meta name="format-detection" content="telephone=no"/>
  <meta name="theme-color" content="#2B1A0C"/>
  <meta name="color-scheme" content="light"/>

  <title>{title}</title>
  <meta name="description" content={description}/>
  {keywords && <meta name="keywords" content={keywords}/>}
  <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'}/>
  <meta name="googlebot" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1'}/>
  <meta name="bingbot"   content={noindex ? 'noindex,nofollow' : 'index,follow'}/>
  <meta name="author" content={author}/>
  <meta name="publisher" content="Solana Nuts"/>
  <meta name="geo.region" content="ES-Z"/>
  <meta name="geo.placename" content="Fayón, Bajo Aragón, Zaragoza"/>
  <meta name="geo.position" content="41.2486;0.3478"/>
  <meta name="ICBM" content="41.2486, 0.3478"/>
  <meta name="rating" content="general"/>
  <meta name="revisit-after" content="7 days"/>
  <meta name="distribution" content="global"/>
  <meta name="language" content={lang === 'es' ? 'Spanish' : 'English'}/>

  <link rel="canonical" href={url}/>

  <!-- hreflang -->
  <link rel="alternate" hreflang="es"        href={SITE + pathname}/>
  <link rel="alternate" hreflang="es-ES"     href={SITE + pathname}/>
  <link rel="alternate" hreflang="en"        href={altEn}/>
  <link rel="alternate" hreflang="x-default" href={SITE + pathname}/>

  <!-- Open Graph -->
  <meta property="og:title"       content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:url"         content={url}/>
  <meta property="og:image"       content={og}/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:image:alt"   content="Solana Nuts — Almendras y nueces naturales del Bajo Aragón"/>
  <meta property="og:type"        content={ogType}/>
  <meta property="og:locale"      content={lang === 'es' ? 'es_ES' : 'en_GB'}/>
  <meta property="og:locale:alternate" content={lang === 'es' ? 'en_GB' : 'es_ES'}/>
  <meta property="og:site_name"   content="Solana Nuts"/>
  {publishedAt && <meta property="article:published_time" content={publishedAt}/>}
  {modifiedAt  && <meta property="article:modified_time"  content={modifiedAt}/>}
  {ogType === 'article' && <meta property="article:author" content={author}/>}
  {ogType === 'article' && <meta property="article:section" content="Frutos secos"/>}

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:site"        content="@solananuts"/>
  <meta name="twitter:creator"     content="@solananuts"/>
  <meta name="twitter:title"       content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image"       content={og}/>
  <meta name="twitter:image:alt"   content="Solana Nuts — Almendras y nueces del Bajo Aragón"/>

  <!-- Verification (placeholders — rellenar al dar de alta en Search Console / Bing / Yandex) -->
  <meta name="google-site-verification" content=""/>
  <meta name="msvalidate.01" content=""/>
  <meta name="yandex-verification" content=""/>

  <!-- Favicons -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>
  <link rel="icon" href="/favicon.ico" sizes="32x32"/>
  <link rel="apple-touch-icon" href="/apple-touch-icon.png"/>
  <link rel="manifest" href="/site.webmanifest"/>

  <!-- DNS / preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link rel="dns-prefetch" href="https://fonts.googleapis.com"/>

  <!-- Fonts: Fraunces (display) · Inter (body) · Caveat (hand) -->
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter:wght@300;400;500;600;700&family=Caveat:wght@500;600&display=swap" rel="stylesheet"/>

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Solana Nuts · Diario de la finca" href={`${SITE}/rss.xml`}/>

  <!-- Sitemap hint -->
  <link rel="sitemap" type="application/xml" title="Sitemap" href={`${SITE}/sitemap-index.xml`}/>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationLd)}/>
  <script type="application/ld+json" set:html={JSON.stringify(websiteLd)}/>
  {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)}/>}
  {schema && (Array.isArray(schema)
    ? schema.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)}/>)
    : <script type="application/ld+json" set:html={JSON.stringify(schema)}/>
  )}
</head>
<body class="font-sans bg-crema text-tierra antialiased overflow-x-hidden">
  <a href="#contenido" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-tierra focus:text-crema focus:px-4 focus:py-2 focus:rounded-full">Saltar al contenido</a>

  <slot/>

  <!-- Scroll reveal -->
  <script>
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        entries => entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); }
        }),
        { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));
    } else {
      document.querySelectorAll('[data-reveal]').forEach(el => el.classList.add('revealed'));
    }
  </script>

  <style is:global>
    :root {
      --tierra: #2B1A0C;
      --almendra: #C9965B;
      --hoja: #4A6741;
      --crema: #FBF6EE;
    }
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body { text-rendering: optimizeLegibility; }
    ::selection { background: #C9965B; color: #2B1A0C; }

    [data-reveal]          { opacity: 0; transform: translateY(22px); transition: opacity .8s ease, transform .8s ease; }
    [data-reveal].revealed { opacity: 1; transform: none; }
    [data-reveal][data-d="1"] { transition-delay: .08s }
    [data-reveal][data-d="2"] { transition-delay: .16s }
    [data-reveal][data-d="3"] { transition-delay: .24s }
    [data-reveal][data-d="4"] { transition-delay: .32s }
    [data-reveal][data-d="5"] { transition-delay: .4s }
    [data-reveal][data-d="6"] { transition-delay: .48s }

    .text-grad {
      background: linear-gradient(135deg, #C9965B 0%, #8B6340 60%, #5C3A1E 100%);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;
    }
    .text-grad-sol {
      background: linear-gradient(135deg, #E4A853 0%, #C9965B 50%, #8B6340 100%);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;
    }
    .text-grad-hoja {
      background: linear-gradient(135deg, #4A6741 0%, #6B8F62 100%);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;
    }

    .section    { padding: clamp(4rem, 9vw, 8rem) 0; position: relative; }
    .section-sm { padding: clamp(2.5rem, 6vw, 5rem) 0; position: relative; }
    .container  { max-width: 1280px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 3rem); }

    .btn {
      display: inline-flex; align-items: center; gap: .55rem;
      padding: .9rem 2rem; border-radius: 100px;
      font-weight: 600; font-size: .95rem;
      transition: background .25s, color .25s, transform .25s, box-shadow .25s, border-color .25s;
      text-decoration: none; cursor: pointer;
      line-height: 1;
    }
    .btn-primary { background: #2B1A0C; color: #FBF6EE; }
    .btn-primary:hover { background: #5C3A1E; transform: translateY(-2px); box-shadow: 0 10px 28px rgba(43,26,12,.28); }

    .btn-almendra { background: #C9965B; color: #fff; }
    .btn-almendra:hover { background: #A67C52; transform: translateY(-2px); box-shadow: 0 10px 28px rgba(201,150,91,.38); }

    .btn-hoja { background: #4A6741; color: #fff; }
    .btn-hoja:hover { background: #344B2F; transform: translateY(-2px); box-shadow: 0 10px 28px rgba(74,103,65,.32); }

    .btn-outline { background: transparent; color: #2B1A0C; border: 1.5px solid #2B1A0C; }
    .btn-outline:hover { background: #2B1A0C; color: #FBF6EE; transform: translateY(-2px); }

    .btn-ghost { background: transparent; color: #5C3A1E; }
    .btn-ghost:hover { background: #EADFC9; color: #2B1A0C; }

    .badge {
      display: inline-flex; align-items: center; gap: .4rem;
      background: #F1DFC2; color: #5C3A1E;
      font-size: .72rem; font-weight: 700;
      letter-spacing: .12em; text-transform: uppercase;
      padding: .38rem .95rem; border-radius: 100px;
      margin-bottom: 1rem;
    }
    .badge-hoja  { background: #D4E8D0; color: #344B2F; }
    .badge-sol   { background: #F7E9D0; color: #5C3A1E; }
    .badge-white { background: rgba(255,255,255,.15); color: #fff; border: 1px solid rgba(255,255,255,.22); }

    .kicker {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem; color: #C9965B;
      display: inline-block; margin-bottom: .5rem;
      font-weight: 600;
    }

    .grano::after {
      content: '';
      position: absolute; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.045'/%3E%3C/svg%3E");
      pointer-events: none; mix-blend-mode: multiply;
    }

    .prose-tierra {
      color: #3E2614;
    }
    .prose-tierra h2 { font-family: 'Fraunces', serif; font-weight: 700; color: #2B1A0C; font-size: clamp(1.75rem, 3.4vw, 2.5rem); line-height: 1.15; margin: 2.25rem 0 1rem; }
    .prose-tierra h3 { font-family: 'Fraunces', serif; font-weight: 700; color: #2B1A0C; font-size: clamp(1.25rem, 2.2vw, 1.55rem); line-height: 1.25; margin: 1.75rem 0 .75rem; }
    .prose-tierra p  { line-height: 1.75; margin-bottom: 1rem; font-size: 1.02rem; }
    .prose-tierra a  { color: #5C3A1E; text-decoration: underline; text-decoration-color: #C9965B; text-underline-offset: 3px; }
    .prose-tierra a:hover { color: #C9965B; }
    .prose-tierra ul { padding-left: 1.25rem; margin: .75rem 0 1.25rem; list-style: disc; }
    .prose-tierra ul li { margin-bottom: .4rem; line-height: 1.7; }
    .prose-tierra strong { color: #2B1A0C; font-weight: 700; }
    .prose-tierra blockquote { border-left: 4px solid #C9965B; padding-left: 1.25rem; margin: 1.5rem 0; font-style: italic; color: #5C3A1E; font-family: 'Fraunces', serif; font-size: 1.1rem; }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] { opacity: 1 !important; transform: none !important; }
      .animate-float, .animate-marquee, .animate-spin-slow { animation: none !important; }
    }
  </style>
</body>
</html>
