---
const reasons = [
  {
    icon: '🏡',
    title: 'Straight from our orchard',
    body: 'No traders, no brokers, no warehouses in between. You buy directly from the family that grew the nut. That means fresher product, faster response and honest pricing.',
    highlight: 'Direct from farm',
  },
  {
    icon: '📋',
    title: 'Full EU compliance & documentation',
    body: 'We supply Certificate of Origin, phytosanitary certificates, mycotoxin test results, pesticide residue analysis and allergen declarations with every shipment.',
    highlight: 'Ready for EU customs',
  },
  {
    icon: '🔢',
    title: 'Any order size',
    body: 'Starting a specialty food range? Order 5 kg to test. Scaling up? We handle full Euro-pallets (800 kg) and multi-pallet container loads weekly.',
    highlight: '5 kg → full container',
  },
  {
    icon: '🌡️',
    title: 'Controlled freshness',
    body: 'Almonds and walnuts are packed to order in our climate-controlled facility. Moisture levels are tested per batch. Shelf life guaranteed minimum 12 months from dispatch.',
    highlight: 'Packed to order',
  },
  {
    icon: '🌍',
    title: 'Pan-European logistics',
    body: 'We ship FCA Spain (you arrange) or DDP delivered to your door in DE, FR, IT, GB, NL, BE, AT and CH. Transit time typically 3–5 working days.',
    highlight: '30+ countries served',
  },
  {
    icon: '💬',
    title: 'Real people, fast replies',
    body: 'Contact us by email, WhatsApp or phone. We reply within 24 hours on working days. Spanish, English, French and German spoken.',
    highlight: 'Human support',
  },
];
---

<section class="section bg-sand" id="why-us">
  <div class="container">

    <div class="text-center max-w-xl mx-auto mb-14" data-reveal>
      <span class="badge">Why European Buyers Choose Us</span>
      <h2 class="font-display text-4xl lg:text-5xl font-bold text-soil">
        The <span class="text-grad">direct farm advantage</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {reasons.map((r, i) => (
        <div
          class="bg-white rounded-2xl p-7 shadow-card hover:shadow-card-hover transition-all duration-400 hover:-translate-y-1 group"
          data-reveal data-d={String((i % 3) + 1)}
        >
          <span class="text-4xl block mb-5 group-hover:animate-float">{r.icon}</span>
          <div class="text-[10px] font-bold uppercase tracking-[.12em] text-almond mb-2">{r.highlight}</div>
          <h3 class="font-display text-xl font-bold text-soil mb-3">{r.title}</h3>
          <p class="text-bark/75 text-sm leading-relaxed">{r.body}</p>
        </div>
      ))}
    </div>

    <!-- Shipping countries visual -->
    <div class="mt-16 bg-soil rounded-3xl p-8 lg:p-12" data-reveal>
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <span class="badge badge-white">Shipping Destinations</span>
          <h3 class="font-display text-3xl font-bold text-cream mt-3 mb-4">
            We ship to <span class="text-almond">all of Europe</span>
          </h3>
          <p class="text-cream/70 leading-relaxed mb-6">
            Our main markets are Germany, France, Italy, the UK, Netherlands and Belgium — but we export to any EU and non-EU country with the appropriate import documentation. Ask us about your specific country.
          </p>
          <a href="/contact" class="btn-almond">Check shipping to your country →</a>
        </div>
        <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
          {[
            ['🇩🇪','Germany'],['🇫🇷','France'],['🇮🇹','Italy'],['🇬🇧','UK'],
            ['🇳🇱','Netherlands'],['🇧🇪','Belgium'],['🇦🇹','Austria'],['🇨🇭','Switzerland'],
            ['🇵🇹','Portugal'],['🇵🇱','Poland'],['🇸🇪','Sweden'],['🇩🇰','Denmark'],
          ].map(([flag, name]) => (
            <div class="bg-white/8 border border-white/12 rounded-xl p-3 text-center hover:bg-white/15 transition-colors">
              <div class="text-2xl mb-1">{flag}</div>
              <div class="text-cream/60 text-xs">{name}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
