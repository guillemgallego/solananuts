---
const navLinks = [
  { href: '/productos',        label: 'Productos' },
  { href: '/variedades',       label: 'Variedades' },
  { href: '/la-finca',         label: 'La finca' },
  { href: '/sostenibilidad',   label: 'Sostenibilidad' },
  { href: '/blog',             label: 'Diario' },
  { href: '/contacto',         label: 'Contacto' },
];
---

<header id="nav" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">

  <div id="topbar" class="bg-tierra text-crema/75 text-xs py-2 transition-all duration-300 overflow-hidden">
    <div class="container flex items-center justify-between flex-wrap gap-2">
      <div class="flex items-center gap-4">
        <span class="flex items-center gap-1.5"><span aria-hidden="true">🌿</span> Finca familiar · Fayón, Bajo Aragón</span>
        <span class="hidden sm:inline opacity-50">·</span>
        <span class="hidden sm:inline flex items-center gap-1.5"><span aria-hidden="true">🚚</span> Envíos a toda España y Europa</span>
        <span class="hidden md:inline opacity-50">·</span>
        <span class="hidden md:inline">Cosecha 2026 disponible</span>
      </div>
      <nav class="flex items-center gap-2" aria-label="Cambiar idioma">
        <a href="/"    class="text-almendra-light font-semibold hover:text-almendra transition-colors" aria-current="true" hreflang="es">ES</a>
        <span class="opacity-30" aria-hidden="true">|</span>
        <a href="/en/" class="hover:text-almendra transition-colors" hreflang="en">EN</a>
      </nav>
    </div>
  </div>

  <nav class="bg-crema/95 backdrop-blur-md border-b border-arena transition-shadow duration-300" id="mainnav" aria-label="Principal">
    <div class="container flex items-center justify-between h-16 lg:h-[68px]">

      <a href="/" class="flex items-center gap-2.5 group" aria-label="Solana Nuts — Inicio">
        <div class="w-10 h-10 rounded-full bg-tierra flex items-center justify-center shadow-warm group-hover:scale-105 transition-transform">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-almendra-light" aria-hidden="true">
            <path d="M12 2.5C12 2.5 5 7.5 5 14a7 7 0 0014 0C19 7.5 12 2.5 12 2.5z" fill="currentColor" opacity=".95"/>
            <path d="M12 3C12 3 12 11 12 18" stroke="#2B1A0C" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="leading-none">
          <span class="font-display font-bold text-xl text-tierra tracking-tight block">Solana Nuts</span>
          <span class="text-[10px] font-semibold tracking-[.18em] uppercase text-almendra block mt-0.5">Tierra · Sol · Alma</span>
        </div>
      </a>

      <ul class="hidden lg:flex items-center gap-0.5">
        {navLinks.map(l => (
          <li>
            <a href={l.href}
               class="px-3.5 py-2 text-sm font-medium text-corteza hover:text-tierra hover:bg-arena rounded-lg transition-colors whitespace-nowrap">
              {l.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-3">
        <a href="/productos"
           class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-corteza border border-arena hover:border-almendra hover:text-almendra px-4 py-2 rounded-lg transition-colors">
          <span aria-hidden="true">🛒</span> Comprar
        </a>
        <a href="/contacto"
           class="btn btn-almendra hidden lg:inline-flex !py-2.5 !px-5 !text-sm">
          Pedir muestra
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <button id="ham" class="lg:hidden flex flex-col gap-1.5 p-1.5 rounded-lg hover:bg-arena transition-colors" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
          <span class="block w-5 h-0.5 bg-tierra rounded transition-all duration-300 origin-center" id="h1"></span>
          <span class="block w-5 h-0.5 bg-tierra rounded transition-all duration-300" id="h2"></span>
          <span class="block w-5 h-0.5 bg-tierra rounded transition-all duration-300 origin-center" id="h3"></span>
        </button>
      </div>
    </div>

    <div id="mobile-menu"
         class="lg:hidden max-h-0 overflow-hidden transition-all duration-500 border-t border-arena/0"
         aria-hidden="true">
      <div class="container py-4 flex flex-col gap-1">
        {navLinks.map(l => (
          <a href={l.href}
             class="px-4 py-3 text-sm font-medium text-corteza hover:text-tierra hover:bg-arena rounded-xl transition-colors">
            {l.label}
          </a>
        ))}
        <div class="pt-3 mt-2 border-t border-arena flex flex-col gap-2">
          <a href="/productos" class="btn btn-outline text-center justify-center !text-sm !py-2.5">Ver productos</a>
          <a href="/contacto" class="btn btn-almendra text-center justify-center !text-sm !py-2.5">Pedir una muestra</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<div class="h-[104px] lg:h-[108px]"></div>

<script>
  const mainnav = document.getElementById('mainnav');
  const topbar  = document.getElementById('topbar');
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 10;
    mainnav?.classList.toggle('shadow-warm', scrolled);
    if (topbar) {
      if (scrolled) { topbar.style.maxHeight = '0'; topbar.style.paddingTop = '0'; topbar.style.paddingBottom = '0'; }
      else          { topbar.style.maxHeight = ''; topbar.style.paddingTop = ''; topbar.style.paddingBottom = ''; }
    }
  });

  const ham  = document.getElementById('ham');
  const menu = document.getElementById('mobile-menu');
  const h1 = document.getElementById('h1');
  const h2 = document.getElementById('h2');
  const h3 = document.getElementById('h3');
  let open = false;
  ham?.addEventListener('click', () => {
    open = !open;
    ham.setAttribute('aria-expanded', String(open));
    ham.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    menu?.setAttribute('aria-hidden', String(!open));
    if (!menu || !h1 || !h2 || !h3) return;
    if (open) {
      menu.style.maxHeight = menu.scrollHeight + 'px';
      menu.classList.add('border-arena');
      h1.style.transform = 'rotate(45deg) translate(3px, 3px)';
      h2.style.opacity = '0';
      h3.style.transform = 'rotate(-45deg) translate(3px, -3px)';
    } else {
      menu.style.maxHeight = '0';
      menu.classList.remove('border-arena');
      h1.style.transform = '';
      h2.style.opacity = '';
      h3.style.transform = '';
    }
  });
</script>
