---
const items = [
  '🌿 Family Farm · Spain',
  '🤍 Solana Almonds',
  '✨ Lauranne Almonds',
  '🌰 Chandler Walnuts',
  '📦 Ships to Germany · France · Italy · UK · Netherlands',
  '🏅 EU Food Safety Certified',
  '🌱 Sustainable Irrigation',
  '🚚 5 kg to Full Pallet',
  '📍 Single-Origin Traceability',
  '🇪🇸 Grown in Spain since 1987',
];
---

<div class="bg-sand border-y border-almond/20 py-3.5 overflow-hidden">
  <div class="flex gap-8 whitespace-nowrap animate-marquee">
    {[...items, ...items].map((item, i) => (
      <span class="text-sm font-semibold text-bark/80 flex-shrink-0">
        {item}
      </span>
    ))}
  </div>
</div>
