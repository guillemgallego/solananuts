---
const items = [
  'Tierra · Sol · Alma',
  'Cosecha a mano',
  'Bajo Aragón · Fayón',
  'Secado natural al aire',
  'Envase reutilizable',
  'Sin plásticos',
  'Agricultura familiar',
  'Del campo a tu mesa',
  'Sin intermediarios',
  '100% natural',
];
---
<div class="bg-almendra-pale text-tierra border-y border-arena/80 overflow-hidden" aria-hidden="true">
  <div class="flex animate-marquee whitespace-nowrap py-3 gap-8">
    {[...items, ...items, ...items].map(t => (
      <span class="text-xs md:text-sm font-semibold tracking-[.2em] uppercase flex items-center gap-8 flex-shrink-0">
        {t}
        <span class="text-almendra text-base" aria-hidden="true">✦</span>
      </span>
    ))}
  </div>
</div>
