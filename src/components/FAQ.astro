---
export interface Props {
  titulo?: string;
  intro?: string;
  items?: Array<{ q: string; a: string }>;
  variante?: 'sand' | 'cream';
}

const defaultItems = [
  { q: '¿Cuándo es la cosecha y en qué fechas recibiré mis almendras?',
    a: 'La cosecha de almendra se realiza entre finales de agosto y principios de octubre. La de nuez Chandler, entre octubre y noviembre. Tras el secado natural, los pedidos empiezan a enviarse a partir de noviembre. Cuando hagas tu pedido, te confirmamos fecha exacta de salida.' },
  { q: '¿Las almendras son ecológicas o naturales?',
    a: 'Nuestra producción es 100% natural: sin fumigación post-cosecha, sin aditivos y con mínima intervención. La certificación ecológica está en trámite. Todo el proceso —desde el riego hasta el envasado— se hace con criterio sostenible y agricultura familiar.' },
  { q: '¿A qué países enviáis? ¿Cuánto cuesta el envío?',
    a: 'Enviamos a toda España peninsular, Baleares y Europa (Francia, Alemania, Italia, Portugal, Países Bajos, Bélgica, Reino Unido, etc.). El envío a Península es gratuito a partir de 45 €. Fuera de España se calcula en el checkout según destino y peso.' },
  { q: '¿Qué diferencia hay entre Almendra Soleta y Almendra Lauranne?',
    a: 'La Soleta (variedad aragonesa del CITA Zaragoza) tiene pepita elíptica, sabor dulce y es ideal a granel o en turrón. La Lauranne es más alargada, con corazón marrón claro, y su piel permanece intacta al hornear — perfecta para panadería y repostería.' },
  { q: '¿Cómo debo conservar las almendras y nueces con cáscara?',
    a: 'Guárdalas en un lugar fresco, seco y oscuro, preferiblemente en su bolsa original de algodón. Así aguantan más de 12 meses sin perder sabor. Una vez peladas, consérvalas en recipiente hermético hasta 6 meses.' },
  { q: '¿Hacéis pedidos al por mayor o a hostelería?',
    a: 'Sí. Trabajamos con pastelerías, tiendas gourmet, chocolateros y restaurantes. Desde 25 kg aplicamos precio de mayorista; para pallet completo (800–1000 kg) ofrecemos condiciones especiales. Escríbenos a info@solananuts.com con tus datos.' },
];

const { titulo = 'Preguntas frecuentes', intro, items = defaultItems, variante = 'sand' } = Astro.props;
const bg = variante === 'cream' ? 'bg-crema' : 'bg-arena';
---
<section class={`section ${bg} relative`} aria-labelledby="faq-heading">
  <div class="container relative">
    <div class="grid lg:grid-cols-[.9fr_1.1fr] gap-12 lg:gap-16 items-start">
      <div data-reveal>
        <span class="kicker">FAQ</span>
        <h2 id="faq-heading" class="font-display text-4xl md:text-5xl font-bold text-tierra mb-5 leading-[1.1]">
          {titulo.split(' ').slice(0, -1).join(' ')} <span class="text-grad">{titulo.split(' ').slice(-1)}</span>
        </h2>
        <p class="text-corteza/80 text-base leading-relaxed mb-7">
          {intro ?? '¿No encuentras tu respuesta? Escríbenos a info@solananuts.com y te contestamos en menos de 24 h.'}
        </p>
        <a href="/contacto" class="btn btn-primary">
          Contactar con la finca →
        </a>
      </div>
      <div class="space-y-3" data-reveal data-d="2">
        {items.map(faq => (
          <details class="group bg-crema rounded-2xl overflow-hidden shadow-card border border-arena">
            <summary class="flex items-center justify-between px-6 py-5 cursor-pointer text-sm md:text-base font-semibold text-tierra list-none hover:bg-arena/40 transition-colors">
              <span class="pr-3">{faq.q}</span>
              <span class="text-almendra text-xl font-bold transition-transform group-open:rotate-45 flex-shrink-0" aria-hidden="true">+</span>
            </summary>
            <div class="px-6 pb-6 text-sm text-corteza/85 leading-relaxed border-t border-arena/60 pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
