---
const year = new Date().getFullYear();
---

<footer class="bg-soil text-cream">
  <!-- Main footer -->
  <div class="container py-16 lg:py-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-10">

      <!-- Brand col -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 group mb-5">
          <div class="w-10 h-10 rounded-full bg-almond/20 border border-almond/30 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-almond">
              <path d="M12 3C12 3 5 8 5 14a7 7 0 0014 0C19 8 12 3 12 3z" fill="currentColor" opacity=".9"/>
              <path d="M12 3C12 3 12 10 12 17" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <span class="font-display font-bold text-xl text-cream block">Solana Nuts</span>
            <span class="text-[10px] font-bold tracking-[.14em] uppercase text-almond block">Spain · Family Farm · Est. 1987</span>
          </div>
        </a>
        <p class="text-cream/60 text-sm leading-relaxed mb-6 max-w-sm">
          Family-owned almond and walnut farm in Spain. We grow Solana almonds, Lauranne almonds and Chandler walnuts and ship direct to buyers across Europe.
        </p>
        <!-- Social -->
        <div class="flex gap-3 mb-8">
          {[
            { label:'Instagram',  href:'https://instagram.com/solananuts', icon:'📷' },
            { label:'LinkedIn',   href:'https://linkedin.com/company/solananuts', icon:'💼' },
            { label:'WhatsApp',   href:'https://wa.me/34600000000', icon:'💬' },
          ].map(s => (
            <a href={s.href} target="_blank" rel="noopener"
               class="w-10 h-10 rounded-xl bg-white/8 border border-white/12 flex items-center justify-center text-lg hover:bg-white/16 hover:border-almond/40 transition-colors"
               aria-label={s.label}>
              {s.icon}
            </a>
          ))}
        </div>
        <!-- Languages in footer -->
        <div class="flex flex-wrap gap-2">
          {[['🇬🇧','EN','/'],['🇩🇪','DE','/de'],['🇫🇷','FR','/fr'],['🇮🇹','IT','/it'],['🇳🇱','NL','/nl']].map(([f,l,h]) => (
            <a href={h}
               class="flex items-center gap-1.5 text-xs font-semibold text-cream/50 hover:text-almond transition-colors px-2.5 py-1.5 rounded-lg hover:bg-white/6">
              {f} {l}
            </a>
          ))}
        </div>
      </div>

      <!-- Products -->
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[.12em] text-almond mb-4">Our Products</h4>
        <ul class="space-y-2.5">
          {[
            ['Solana Almonds',               '/varieties/solana-almond'],
            ['Lauranne Almonds',             '/varieties/lauranne-almond'],
            ['Chandler Walnuts',             '/varieties/chandler-walnut'],
            ['Raw & Natural',                '/varieties'],
            ['Blanched Almonds',             '/varieties#formats'],
            ['Roasted Almonds',              '/varieties#formats'],
            ['Wholesale Packs',              '/contact#wholesale'],
            ['Sample Request',               '/contact'],
          ].map(([l,h]) => (
            <li><a href={h} class="text-cream/55 hover:text-almond text-sm transition-colors">{l}</a></li>
          ))}
        </ul>
      </div>

      <!-- SEO pages -->
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[.12em] text-almond mb-4">Learn & Buy</h4>
        <ul class="space-y-2.5">
          {[
            ['Buy Spanish Almonds Online',   '/buy-spanish-almonds'],
            ['Buy Almonds Europe Wholesale', '/wholesale-almonds-europe'],
            ['Chandler Walnuts Supplier',    '/chandler-walnut-supplier'],
            ['Almond Varieties Guide',       '/varieties'],
            ['Nutritional Information',      '/nutrition'],
            ['Almond Health Benefits',       '/blog/almond-health-benefits'],
            ['Walnut Health Benefits',       '/blog/walnut-health-benefits'],
            ['Recipes',                      '/recipes'],
          ].map(([l,h]) => (
            <li><a href={h} class="text-cream/55 hover:text-almond text-sm transition-colors">{l}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[.12em] text-almond mb-4">Company</h4>
        <ul class="space-y-2.5">
          {[
            ['Our Farm Story',          '/about'],
            ['Sustainability',          '/sustainability'],
            ['Certifications',          '/certifications'],
            ['Shipping & Logistics',    '/shipping'],
            ['Blog / Journal',          '/blog'],
            ['Contact Us',              '/contact'],
            ['Privacy Policy',          '/privacy'],
            ['Legal Notice',            '/legal'],
          ].map(([l,h]) => (
            <li><a href={h} class="text-cream/55 hover:text-almond text-sm transition-colors">{l}</a></li>
          ))}
        </ul>

        <!-- Contact quick links -->
        <div class="mt-6 space-y-2">
          <a href="mailto:hello@solananuts.com"
             class="flex items-center gap-2 text-sm text-cream/55 hover:text-almond transition-colors">
            📧 hello@solananuts.com
          </a>
          <a href="https://wa.me/34600000000"
             class="flex items-center gap-2 text-sm text-cream/55 hover:text-almond transition-colors">
            📱 WhatsApp us
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/8">
    <div class="container py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-cream/30">
      <p>© {year} Solana Nuts SL · All rights reserved · Spain</p>
      <p>Made with ❤️ by a family who loves almonds · Astro + Tailwind</p>
    </div>
  </div>
</footer>
