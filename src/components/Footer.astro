---
const year = new Date().getFullYear();
const col1 = [
  { href: '/productos', label: 'Todos los productos' },
  { href: '/variedades/almendra-soleta', label: 'Almendra Soleta' },
  { href: '/variedades/almendra-lauranne', label: 'Almendra Lauranne' },
  { href: '/variedades/nuez-chandler', label: 'Nuez Chandler' },
];
const col2 = [
  { href: '/la-finca', label: 'La finca' },
  { href: '/sostenibilidad', label: 'Sostenibilidad' },
  { href: '/blog', label: 'Diario de la finca' },
  { href: '/preguntas-frecuentes', label: 'Preguntas frecuentes' },
];
const col3 = [
  { href: '/contacto', label: 'Contacto' },
  { href: '/comprar-almendras-online', label: 'Comprar almendras' },
  { href: '/aviso-legal', label: 'Aviso legal' },
  { href: '/politica-privacidad', label: 'Política de privacidad' },
  { href: '/politica-cookies', label: 'Política de cookies' },
];
---
<footer class="bg-tierra text-crema relative overflow-hidden grano" role="contentinfo">
  <div class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-almendra/8 rounded-full blur-3xl" aria-hidden="true"></div>

  <div class="container relative py-16 lg:py-20">
    <div class="grid lg:grid-cols-[1.3fr_1fr_1fr_1fr] gap-10 lg:gap-12 mb-14">

      <div>
        <a href="/" class="flex items-center gap-3 mb-5">
          <div class="w-11 h-11 rounded-full bg-crema flex items-center justify-center" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M12 2.5C12 2.5 5 7.5 5 14a7 7 0 0014 0C19 7.5 12 2.5 12 2.5z" fill="#C9965B"/>
              <path d="M12 3C12 3 12 11 12 18" stroke="#2B1A0C" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="leading-none">
            <span class="font-display font-bold text-xl text-crema tracking-tight block">Solana Nuts</span>
            <span class="text-[10px] font-semibold tracking-[.18em] uppercase text-almendra-light block mt-0.5">Tierra · Sol · Alma</span>
          </div>
        </a>
        <p class="text-crema/70 text-sm leading-relaxed mb-5 max-w-sm">
          Finca familiar de almendras y nueces en Fayón, Bajo Aragón. Cultivamos Almendra Soleta,
          Lauranne y Nuez Chandler con cosecha a mano, secado al aire y envase reutilizable.
        </p>
        <div class="flex gap-2 mb-6" aria-label="Redes sociales">
          <a href="https://instagram.com/solananuts" aria-label="Instagram" rel="me" class="w-9 h-9 rounded-full bg-white/8 hover:bg-almendra flex items-center justify-center transition-colors">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 01-1.38-.9 3.7 3.7 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.3-1.45.72-2.12 1.38C1.35 2.68.93 3.35.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.3.79.72 1.45 1.38 2.12.67.67 1.33 1.08 2.12 1.38.76.3 1.64.5 2.91.56 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.3 1.45-.72 2.12-1.38.67-.67 1.08-1.33 1.38-2.12.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.87 5.87 0 00-1.38-2.12A5.87 5.87 0 0019.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 100 12.32 6.16 6.16 0 000-12.32zM12 16a4 4 0 110-8 4 4 0 010 8zm6.41-11.85a1.44 1.44 0 100 2.88 1.44 1.44 0 000-2.88z"/></svg>
          </a>
          <a href="https://t.me/solananuts" aria-label="Telegram" class="w-9 h-9 rounded-full bg-white/8 hover:bg-almendra flex items-center justify-center transition-colors">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.6 8.3l-1.87 8.8c-.14.63-.51.79-1.03.49l-2.85-2.1-1.37 1.32c-.15.15-.28.28-.58.28l.2-2.9 5.3-4.8c.23-.2-.05-.32-.36-.12L8.5 13.6l-2.8-.87c-.61-.19-.62-.61.13-.9l10.96-4.22c.5-.19.95.12.81.7z"/></svg>
          </a>
        </div>
        <address class="text-xs text-crema/55 space-y-1 leading-relaxed not-italic">
          <div>📍 Fayón, Zaragoza (Bajo Aragón, España)</div>
          <div>📧 <a href="mailto:info@solananuts.com" class="hover:text-almendra-light">info@solananuts.com</a></div>
          <div>📱 +34 XXX XXX XXX</div>
        </address>
      </div>

      <nav aria-label="Productos">
        <div class="text-[11px] font-bold uppercase tracking-[.2em] text-almendra mb-4">Productos</div>
        <ul class="space-y-2.5">
          {col1.map(l => (
            <li><a href={l.href} class="text-sm text-crema/75 hover:text-almendra-light transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Nuestra casa">
        <div class="text-[11px] font-bold uppercase tracking-[.2em] text-almendra mb-4">La casa</div>
        <ul class="space-y-2.5">
          {col2.map(l => (
            <li><a href={l.href} class="text-sm text-crema/75 hover:text-almendra-light transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Información">
        <div class="text-[11px] font-bold uppercase tracking-[.2em] text-almendra mb-4">Información</div>
        <ul class="space-y-2.5">
          {col3.map(l => (
            <li><a href={l.href} class="text-sm text-crema/75 hover:text-almendra-light transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-crema/55">
      <div>
        © {year} Solana Nuts · Todos los derechos reservados · Finca familiar · Fayón, Zaragoza
      </div>
      <div class="flex items-center gap-4">
        <a href="/sitemap-index.xml" class="hover:text-almendra-light">Sitemap</a>
        <span aria-hidden="true">·</span>
        <a href="/rss.xml" class="hover:text-almendra-light">RSS</a>
        <span aria-hidden="true">·</span>
        <span>Hecho en Aragón con ♡</span>
      </div>
    </div>
  </div>
</footer>
