---
---
<section id="contacto" class="section bg-tierra text-crema relative overflow-hidden grano" aria-labelledby="contacto-heading">
  <div class="absolute inset-0 bg-gradient-to-br from-tierra via-corteza/95 to-tierra" aria-hidden="true"></div>
  <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-almendra/12 rounded-full blur-3xl" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-hoja/12 rounded-full blur-3xl" aria-hidden="true"></div>

  <div class="container relative">
    <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">

      <div data-reveal>
        <span class="badge badge-white">Contacto</span>
        <h2 id="contacto-heading" class="font-display text-4xl md:text-5xl font-bold text-crema mb-5 leading-[1.1]">
          Escríbenos, te<br/><span class="text-grad-sol italic">respondemos en 24 h</span>
        </h2>
        <p class="text-crema/75 text-base leading-relaxed mb-8">
          Particular, tienda gourmet, pastelería, restaurante o distribuidor — cuéntanos qué buscas y
          te preparamos una muestra o presupuesto personalizado.
        </p>

        <div class="space-y-4 mb-8">
          <a href="mailto:info@solananuts.com" class="flex items-start gap-4 p-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
            <div class="w-11 h-11 rounded-xl bg-almendra/20 flex items-center justify-center text-almendra-light flex-shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5a2 2 0 012-2h10a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" stroke="currentColor" stroke-width="1.5"/><path d="M3 6l7 5 7-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div>
              <div class="text-xs font-bold uppercase tracking-[.15em] text-almendra-light mb-0.5">Email</div>
              <div class="text-crema font-semibold">info@solananuts.com</div>
            </div>
          </a>

          <div class="flex items-start gap-4 p-4 rounded-2xl bg-white/5 border border-white/10">
            <div class="w-11 h-11 rounded-xl bg-hoja/25 flex items-center justify-center text-hoja-light flex-shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 18s7-6 7-11a7 7 0 10-14 0c0 5 7 11 7 11z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="7" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <div>
              <div class="text-xs font-bold uppercase tracking-[.15em] text-hoja-light mb-0.5">La finca</div>
              <div class="text-crema font-semibold">Fayón, Zaragoza · Bajo Aragón</div>
              <div class="text-crema/60 text-sm mt-0.5">Visitas con cita previa</div>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 rounded-2xl bg-white/5 border border-white/10">
            <div class="w-11 h-11 rounded-xl bg-almendra/20 flex items-center justify-center text-almendra-light flex-shrink-0" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="5" y="2" width="10" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 15h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div>
              <div class="text-xs font-bold uppercase tracking-[.15em] text-almendra-light mb-0.5">Teléfono</div>
              <div class="text-crema font-semibold">+34 XXX XXX XXX</div>
              <div class="text-crema/60 text-sm mt-0.5">L–V · 9:00–14:00 h</div>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-3 pt-6 border-t border-white/10">
          <span class="text-xs text-crema/60 uppercase tracking-wider">Síguenos:</span>
          <a href="https://instagram.com/solananuts" rel="me" aria-label="Instagram de Solana Nuts" class="w-9 h-9 rounded-full bg-white/8 hover:bg-almendra flex items-center justify-center transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-crema" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 01-1.38-.9 3.7 3.7 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.3-1.45.72-2.12 1.38C1.35 2.68.93 3.35.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.3.79.72 1.45 1.38 2.12.67.67 1.33 1.08 2.12 1.38.76.3 1.64.5 2.91.56 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.3 1.45-.72 2.12-1.38.67-.67 1.08-1.33 1.38-2.12.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.87 5.87 0 00-1.38-2.12A5.87 5.87 0 0019.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 100 12.32 6.16 6.16 0 000-12.32zM12 16a4 4 0 110-8 4 4 0 010 8zm6.41-11.85a1.44 1.44 0 100 2.88 1.44 1.44 0 000-2.88z"/></svg>
          </a>
          <a href="https://t.me/solananuts" aria-label="Telegram de Solana Nuts" class="w-9 h-9 rounded-full bg-white/8 hover:bg-almendra flex items-center justify-center transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-crema" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.6 8.3l-1.87 8.8c-.14.63-.51.79-1.03.49l-2.85-2.1-1.37 1.32c-.15.15-.28.28-.58.28l.2-2.9 5.3-4.8c.23-.2-.05-.32-.36-.12L8.5 13.6l-2.8-.87c-.61-.19-.62-.61.13-.9l10.96-4.22c.5-.19.95.12.81.7z"/></svg>
          </a>
        </div>
      </div>

      <div data-reveal data-d="2">
        <form action="https://formspree.io/f/REEMPLAZAR_ID" method="POST" class="bg-crema text-tierra rounded-3xl p-7 lg:p-9 shadow-warm-lg space-y-5" aria-label="Formulario de contacto">
          <input type="hidden" name="_language" value="es"/>
          <input type="text"   name="_gotcha"  style="display:none" tabindex="-1" autocomplete="off"/>

          <div class="grid sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="text-xs font-bold uppercase tracking-wider text-corteza block mb-1.5">Nombre*</span>
              <input required type="text" name="nombre" autocomplete="name"
                     class="w-full bg-arena-light border border-arena rounded-xl px-4 py-3 text-sm text-tierra placeholder-piedra focus:outline-none focus:border-almendra focus:ring-2 focus:ring-almendra/30 transition"
                     placeholder="Nombre y apellido"/>
            </label>
            <label class="block">
              <span class="text-xs font-bold uppercase tracking-wider text-corteza block mb-1.5">Email*</span>
              <input required type="email" name="email" autocomplete="email"
                     class="w-full bg-arena-light border border-arena rounded-xl px-4 py-3 text-sm text-tierra placeholder-piedra focus:outline-none focus:border-almendra focus:ring-2 focus:ring-almendra/30 transition"
                     placeholder="tu@email.com"/>
            </label>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="text-xs font-bold uppercase tracking-wider text-corteza block mb-1.5">Teléfono</span>
              <input type="tel" name="telefono" autocomplete="tel"
                     class="w-full bg-arena-light border border-arena rounded-xl px-4 py-3 text-sm text-tierra placeholder-piedra focus:outline-none focus:border-almendra focus:ring-2 focus:ring-almendra/30 transition"
                     placeholder="+34 ..."/>
            </label>
            <label class="block">
              <span class="text-xs font-bold uppercase tracking-wider text-corteza block mb-1.5">Soy*</span>
              <select required name="tipo"
                      class="w-full bg-arena-light border border-arena rounded-xl px-4 py-3 text-sm text-tierra focus:outline-none focus:border-almendra focus:ring-2 focus:ring-almendra/30 transition">
                <option value="">Selecciona...</option>
                <option value="particular">Particular</option>
                <option value="tienda">Tienda / gourmet</option>
                <option value="hosteleria">Hostelería / pastelería</option>
                <option value="distribuidor">Distribuidor / mayorista</option>
                <option value="exportador">Exportador</option>
                <option value="prensa">Prensa / medio</option>
              </select>
            </label>
          </div>

          <label class="block">
            <span class="text-xs font-bold uppercase tracking-wider text-corteza block mb-1.5">¿Qué te interesa?</span>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
              {['Soleta', 'Lauranne', 'Chandler', 'Muestra gratuita', 'Por mayor', 'Otro'].map(op => (
                <label class="flex items-center gap-2 bg-arena-light border border-arena rounded-xl px-3 py-2.5 cursor-pointer hover:border-almendra transition text-sm">
                  <input type="checkbox" name="interes[]" value={op} class="accent-almendra"/>
                  <span>{op}</span>
                </label>
              ))}
            </div>
          </label>

          <label class="block">
            <span class="text-xs font-bold uppercase tracking-wider text-corteza block mb-1.5">Mensaje*</span>
            <textarea required name="mensaje" rows="4"
                      class="w-full bg-arena-light border border-arena rounded-xl px-4 py-3 text-sm text-tierra placeholder-piedra focus:outline-none focus:border-almendra focus:ring-2 focus:ring-almendra/30 transition resize-none"
                      placeholder="Cuéntanos qué buscas (variedad, formato, fechas…)"></textarea>
          </label>

          <label class="flex items-start gap-2.5 text-xs text-corteza/85 leading-relaxed">
            <input required type="checkbox" name="rgpd" class="mt-0.5 accent-almendra"/>
            <span>Acepto la <a href="/politica-privacidad" class="underline hover:text-almendra">política de privacidad</a> y el tratamiento de mis datos para responder a esta solicitud.</span>
          </label>

          <button type="submit" class="btn btn-primary w-full justify-center !text-base">
            Enviar mensaje
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <p class="text-center text-xs text-piedra">Te responderemos en menos de 24 horas laborables.</p>
        </form>
      </div>
    </div>
  </div>
</section>
