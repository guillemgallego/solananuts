---
---

<section class="section bg-cream" id="contact">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: contact info -->
      <div data-reveal>
        <span class="badge">Get in Touch</span>
        <h2 class="font-display text-4xl lg:text-5xl font-bold text-soil mb-6">
          Let's talk<br/><span class="text-grad">almonds & walnuts</span>
        </h2>
        <p class="text-bark/80 text-lg leading-relaxed mb-8">
          Whether you want a free sample box, a price list for wholesale, or just want to ask about our varieties — we're a family business and we reply personally.
        </p>

        <div class="space-y-5 mb-10">
          {[
            { icon:'📧', label:'Email', value:'hello@solananuts.com', href:'mailto:hello@solananuts.com' },
            { icon:'📱', label:'WhatsApp', value:'+34 600 000 000', href:'https://wa.me/34600000000' },
            { icon:'📍', label:'Farm location', value:'Spain (exact address on request)', href:null },
            { icon:'🕐', label:'Response time', value:'Within 24h on working days', href:null },
          ].map(c => (
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 bg-sand rounded-xl flex items-center justify-center flex-shrink-0 text-xl">{c.icon}</div>
              <div>
                <div class="text-[11px] font-bold uppercase tracking-[.1em] text-stone mb-0.5">{c.label}</div>
                {c.href
                  ? <a href={c.href} class="text-soil font-semibold hover:text-almond transition-colors">{c.value}</a>
                  : <p class="text-soil font-semibold">{c.value}</p>
                }
              </div>
            </div>
          ))}
        </div>

        <!-- Languages -->
        <div class="bg-sand rounded-2xl p-6">
          <p class="text-[11px] font-bold uppercase tracking-[.1em] text-stone mb-3">We speak:</p>
          <div class="flex flex-wrap gap-3">
            {[['🇬🇧','English'],['🇪🇸','Spanish'],['🇩🇪','German'],['🇫🇷','French']].map(([f,l]) => (
              <div class="flex items-center gap-2 bg-white rounded-full px-4 py-2 text-sm font-semibold text-bark">
                <span>{f}</span> {l}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="bg-white rounded-3xl shadow-warm p-8 lg:p-10" data-reveal data-d="2">
        <h3 class="font-display text-2xl font-bold text-soil mb-6">Send us a message</h3>

        <form
          name="contact"
          method="POST"
          action="/contact/success"
          class="space-y-5"
          novalidate
        >
          <!-- Honeypot (spam protection) -->
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off"/>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-xs font-bold uppercase tracking-[.1em] text-stone mb-1.5">Full Name *</label>
              <input
                id="name" name="name" type="text" required
                placeholder="Jan Müller"
                class="w-full bg-cream border border-sand rounded-xl px-4 py-3 text-soil placeholder:text-stone/60 text-sm focus:outline-none focus:border-almond focus:ring-2 focus:ring-almond/20 transition-colors"
              />
            </div>
            <div>
              <label for="company" class="block text-xs font-bold uppercase tracking-[.1em] text-stone mb-1.5">Company / Shop</label>
              <input
                id="company" name="company" type="text"
                placeholder="Organic Deli Berlin"
                class="w-full bg-cream border border-sand rounded-xl px-4 py-3 text-soil placeholder:text-stone/60 text-sm focus:outline-none focus:border-almond focus:ring-2 focus:ring-almond/20 transition-colors"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="email" class="block text-xs font-bold uppercase tracking-[.1em] text-stone mb-1.5">Email *</label>
              <input
                id="email" name="email" type="email" required
                placeholder="jan@deli.de"
                class="w-full bg-cream border border-sand rounded-xl px-4 py-3 text-soil placeholder:text-stone/60 text-sm focus:outline-none focus:border-almond focus:ring-2 focus:ring-almond/20 transition-colors"
              />
            </div>
            <div>
              <label for="country" class="block text-xs font-bold uppercase tracking-[.1em] text-stone mb-1.5">Country *</label>
              <select
                id="country" name="country" required
                class="w-full bg-cream border border-sand rounded-xl px-4 py-3 text-soil text-sm focus:outline-none focus:border-almond focus:ring-2 focus:ring-almond/20 transition-colors cursor-pointer"
              >
                <option value="" disabled selected>Select country</option>
                {['Germany','France','Italy','United Kingdom','Netherlands','Belgium','Austria','Switzerland','Spain','Other EU','Outside EU'].map(c => (
                  <option value={c}>{c}</option>
                ))}
              </select>
            </div>
          </div>

          <!-- Enquiry type -->
          <div>
            <label class="block text-xs font-bold uppercase tracking-[.1em] text-stone mb-2">I'm interested in *</label>
            <div class="grid grid-cols-2 gap-2">
              {[
                { id:'req-sample',    label:'🎁 Free Sample', name:'enquiry_type', value:'sample' },
                { id:'req-wholesale', label:'📦 Wholesale',   name:'enquiry_type', value:'wholesale' },
                { id:'req-retail',    label:'🛍️ Retail Pack', name:'enquiry_type', value:'retail' },
                { id:'req-info',      label:'💬 Information',  name:'enquiry_type', value:'info' },
              ].map(opt => (
                <label class="flex items-center gap-2.5 bg-cream border border-sand rounded-xl px-4 py-3 cursor-pointer hover:border-almond transition-colors has-[:checked]:border-almond has-[:checked]:bg-almond/8">
                  <input type="radio" name={opt.name} value={opt.value} class="accent-almond w-4 h-4 flex-shrink-0"/>
                  <span class="text-sm font-medium text-soil">{opt.label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Variety -->
          <div>
            <label class="block text-xs font-bold uppercase tracking-[.1em] text-stone mb-2">Variety / product</label>
            <div class="flex flex-wrap gap-2">
              {[
                { id:'v-solana',   label:'🤍 Solana Almond',   value:'solana' },
                { id:'v-lauranne', label:'✨ Lauranne Almond',  value:'lauranne' },
                { id:'v-chandler', label:'🌰 Chandler Walnut',  value:'chandler' },
                { id:'v-all',      label:'All varieties',       value:'all' },
              ].map(v => (
                <label class="flex items-center gap-2 border border-sand rounded-full px-4 py-2 cursor-pointer hover:border-almond transition-colors has-[:checked]:border-almond has-[:checked]:bg-almond/8 bg-cream text-sm">
                  <input type="checkbox" name="variety[]" value={v.value} class="accent-almond w-3.5 h-3.5"/>
                  <span class="font-medium text-bark">{v.label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Volume -->
          <div>
            <label for="volume" class="block text-xs font-bold uppercase tracking-[.1em] text-stone mb-1.5">Approximate volume needed</label>
            <select
              id="volume" name="volume"
              class="w-full bg-cream border border-sand rounded-xl px-4 py-3 text-soil text-sm focus:outline-none focus:border-almond focus:ring-2 focus:ring-almond/20 transition-colors cursor-pointer"
            >
              <option value="">Not sure yet</option>
              <option>5–25 kg (trial / sample)</option>
              <option>25–100 kg (small batch)</option>
              <option>100–500 kg (regular order)</option>
              <option>500 kg – 1 tonne (wholesale)</option>
              <option>1+ tonnes (container / distributor)</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-xs font-bold uppercase tracking-[.1em] text-stone mb-1.5">Message</label>
            <textarea
              id="message" name="message" rows="4"
              placeholder="Tell us a bit about your business and what you need. We'll reply within 24 hours..."
              class="w-full bg-cream border border-sand rounded-xl px-4 py-3 text-soil placeholder:text-stone/60 text-sm focus:outline-none focus:border-almond focus:ring-2 focus:ring-almond/20 transition-colors resize-none"
            ></textarea>
          </div>

          <!-- GDPR -->
          <label class="flex items-start gap-3 text-xs text-stone cursor-pointer">
            <input type="checkbox" required class="mt-0.5 accent-almond w-4 h-4 flex-shrink-0"/>
            <span>I agree to Solana Nuts storing my contact data to respond to this enquiry. View our <a href="/privacy" class="text-almond underline hover:text-bark">privacy policy</a>.</span>
          </label>

          <button type="submit" class="w-full btn-almond text-center justify-center !py-3.5">
            Send Message
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
