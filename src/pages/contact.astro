---
import Base    from '../layouts/Base.astro';
import Nav     from '../components/Nav.astro';
import Contact from '../components/Contact.astro';
import Footer  from '../components/Footer.astro';
---

<Base
  title="Contact Solana Nuts | Buy Spanish Almonds & Walnuts Wholesale Europe"
  description="Contact our family farm to request free samples, wholesale pricing or shipping info for Solana almonds, Lauranne almonds and Chandler walnuts. We reply within 24 hours."
  canonical="/contact"
  lang="en"
>
  <Nav />
  <main>
    <!-- Page hero -->
    <div class="bg-soil py-16 text-center relative overflow-hidden grain">
      <div class="absolute inset-0 bg-gradient-to-br from-soil to-bark/80"></div>
      <div class="container relative z-10">
        <nav class="flex justify-center items-center gap-2 text-sm text-cream/50 mb-4">
          <a href="/" class="hover:text-almond transition-colors">Home</a>
          <span>›</span>
          <span class="text-cream/70">Contact</span>
        </nav>
        <h1 class="font-display text-5xl font-bold text-cream mb-3">
          Get in <span class="text-grad">Touch</span>
        </h1>
        <p class="text-cream/70 text-lg max-w-xl mx-auto">
          Sample requests, wholesale enquiries or just a chat about almonds — we're a family and we reply personally within 24 hours.
        </p>
      </div>
    </div>
    <Contact />
  </main>
  <Footer />
</Base>
