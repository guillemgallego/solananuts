---
import Base    from '../layouts/Base.astro';
import Nav     from '../components/Nav.astro';
import Contact from '../components/Contact.astro';
import Footer  from '../components/Footer.astro';
---

<Base
  title="Buy Spanish Almonds Online | Wholesale & Retail — Solana Nuts"
  description="Buy premium Spanish almonds online: Solana and Lauranne varieties, direct from our family farm in Spain. Wholesale from 25 kg. Ships to Germany, France, Italy, UK, Netherlands. Free sample available."
  canonical="/buy-spanish-almonds"
  lang="en"
>
  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://solananuts.com"},
      {"@type":"ListItem","position":2,"name":"Buy Spanish Almonds","item":"https://solananuts.com/buy-spanish-almonds"}
    ]
  }
  </script>

  <Nav />
  <main>

    <!-- Hero -->
    <div class="bg-soil relative grain overflow-hidden py-20">
      <div class="absolute inset-0 bg-gradient-to-br from-soil to-bark/90"></div>
      <div class="absolute right-0 top-0 w-[500px] h-[500px] bg-almond/10 rounded-full blur-[100px]"></div>
      <div class="container relative z-10">
        <nav class="flex items-center gap-2 text-sm text-cream/50 mb-6">
          <a href="/" class="hover:text-almond transition-colors">Home</a>
          <span>›</span>
          <span class="text-cream/70">Buy Spanish Almonds</span>
        </nav>
        <div class="max-w-3xl">
          <span class="badge badge-white">Direct from Farm · Spain</span>
          <h1 class="font-display text-5xl lg:text-6xl font-bold text-cream mt-4 mb-5">
            Buy Spanish Almonds<br/>
            <span class="text-grad">Online — Direct from the Finca</span>
          </h1>
          <p class="text-cream/75 text-xl leading-relaxed mb-8 max-w-2xl">
            Solana and Lauranne almonds grown on our family farm in Spain. No middlemen. Ships to Germany, France, Italy, UK, Netherlands and all Europe. Wholesale from 25 kg. Free sample available.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact" class="btn-almond text-lg">Request Free Sample</a>
            <a href="/contact#wholesale" class="btn-outline !border-white/30 !text-cream hover:!bg-white/10 hover:!text-cream text-lg">Get Wholesale Prices</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <section class="section bg-cream">
      <div class="container">
        <div class="grid lg:grid-cols-3 gap-12">

          <!-- Main content (2/3) -->
          <div class="lg:col-span-2 space-y-10">

            <div data-reveal>
              <h2 class="font-display text-3xl font-bold text-soil mb-4">Why buy Spanish almonds from Solana Nuts?</h2>
              <p class="text-bark/80 leading-relaxed mb-4">Spain is the world's second-largest almond exporter, and for good reason. Spanish almond varieties — including our <strong>Solana</strong> and <strong>Lauranne</strong> — are prized across Europe for their <strong>higher oil content, richer flavour, and hard non-porous shell</strong> that eliminates the need for post-harvest fumigation required by US Californian almonds.</p>
              <p class="text-bark/80 leading-relaxed mb-4">When you buy almonds from Solana Nuts, you're buying directly from the family that grew them. We own the orchard, operate our own processing facility, and handle all export documentation. That means better freshness, a cleaner supply chain, and a real person you can call.</p>
              <p class="text-bark/80 leading-relaxed">Our almonds are available raw, blanched, roasted, sliced or as almond flour — from 5 kg retail packs to full container loads for distributors.</p>
            </div>

            <div data-reveal>
              <h2 class="font-display text-3xl font-bold text-soil mb-6">Our two almond varieties</h2>
              <div class="grid sm:grid-cols-2 gap-5">
                {[
                  { name:'Solana Almond', emoji:'🤍', color:'#F5EDD8', desc:'Round, sweet, traditional Spanish variety. Premium flavour with low bitterness. Ideal for retail snacking, nougat, marzipan and almond paste. Hard shell — no fumigation required.', href:'/varieties/solana-almond' },
                  { name:'Lauranne Almond', emoji:'✨', color:'#EAE8D8', desc:'Large, elongated, sweet. Franco-Spanish cross. The skin stays perfectly intact when baked — making it the favourite of European chocolatiers and patissiers. Commands premium retail prices.', href:'/varieties/lauranne-almond' },
                ].map(p => (
                  <div class="rounded-2xl overflow-hidden border border-sand hover:shadow-card-hover transition-all hover:-translate-y-1">
                    <div class="p-6 text-5xl text-center" style={`background:${p.color}`}>{p.emoji}</div>
                    <div class="p-5">
                      <h3 class="font-display text-xl font-bold text-soil mb-2">{p.name}</h3>
                      <p class="text-bark/75 text-sm leading-relaxed mb-4">{p.desc}</p>
                      <a href={p.href} class="text-almond text-sm font-semibold hover:text-bark transition-colors">Full variety profile →</a>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div data-reveal>
              <h2 class="font-display text-3xl font-bold text-soil mb-4">How to order Spanish almonds from Spain</h2>
              <ol class="space-y-4">
                {[
                  { step:'1', title:'Request your free sample', desc:'Fill out our contact form. We\'ll send a sample box with all three varieties within 3 working days. No charge, no commitment.' },
                  { step:'2', title:'Choose your variety and format', desc:'Solana or Lauranne almonds (or both). Raw, blanched, roasted, sliced, diced or ground. We\'ll discuss which format suits your use case.' },
                  { step:'3', title:'Agree pricing and logistics', desc:'We\'ll send you a quote with pricing per kg at your quantity tier, plus shipping options (FCA Spain or DDP your door).' },
                  { step:'4', title:'Receive your order', desc:'Most EU destinations receive within 3–5 working days. Full documentation (phyto certificate, test results, origin certificate) included.' },
                ].map(s => (
                  <li class="flex items-start gap-4">
                    <span class="w-9 h-9 bg-almond text-white rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0">{s.step}</span>
                    <div>
                      <strong class="text-soil block mb-1">{s.title}</strong>
                      <p class="text-bark/75 text-sm leading-relaxed">{s.desc}</p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          </div>

          <!-- Sidebar (1/3) -->
          <div class="space-y-6" data-reveal data-d="2">
            <!-- Quick CTA -->
            <div class="bg-soil rounded-2xl p-6 text-cream sticky top-24">
              <h3 class="font-display text-xl font-bold mb-3">Ready to order?</h3>
              <p class="text-cream/65 text-sm mb-5">Get a free sample or request wholesale pricing. We reply within 24 hours.</p>
              <div class="space-y-3">
                <a href="/contact" class="btn-almond w-full text-center justify-center">Request Free Sample</a>
                <a href="/contact#wholesale" class="btn-outline !border-white/30 !text-cream hover:!bg-white/10 hover:!text-cream w-full text-center justify-center text-sm">Get Wholesale Price List</a>
              </div>
              <div class="mt-5 space-y-2 text-xs text-cream/50">
                <div>✓ Minimum 5 kg order</div>
                <div>✓ Ships to all Europe</div>
                <div>✓ EU food safety certified</div>
                <div>✓ Free sample available</div>
              </div>
            </div>

            <!-- Key facts -->
            <div class="bg-sand rounded-2xl p-6 space-y-4">
              <h3 class="font-display text-lg font-bold text-soil">Spanish almonds: key facts</h3>
              {[
                ['Origin','Spain (our own finca)'],
                ['Varieties','Solana, Lauranne'],
                ['Shell type','Hard, non-porous'],
                ['Oil content','Higher than Californian'],
                ['Fumigation','Not required'],
                ['Available formats','Raw, blanched, roasted, flour'],
                ['Min. order','5 kg'],
                ['Certifications','EU food safety, origin cert'],
              ].map(([k,v]) => (
                <div class="flex justify-between text-sm border-b border-sand/60 pb-2 last:border-0 last:pb-0">
                  <span class="text-stone font-medium">{k}</span>
                  <span class="text-soil font-semibold text-right max-w-[55%]">{v}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <Contact />
  </main>
  <Footer />
</Base>
