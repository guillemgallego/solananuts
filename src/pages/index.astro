---
import Base    from '../layouts/Base.astro';
import Nav     from '../components/Nav.astro';
import Hero    from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Products from '../components/Products.astro';
import About   from '../components/About.astro';
import WhyUs   from '../components/WhyUs.astro';
import Contact  from '../components/Contact.astro';
import Footer  from '../components/Footer.astro';
---

<Base
  title="Solana Nuts | Premium Spanish Almonds & Walnuts · Direct Farm Export to Europe"
  description="Buy premium Spanish almonds (Solana & Lauranne) and Chandler walnuts direct from our family farm in Spain. Wholesale & retail, ships to Germany, France, Italy, UK, Netherlands and all Europe."
  canonical="/"
  lang="en"
>
  <Nav />
  <main>
    <Hero />
    <Marquee />
    <Products />

    <!-- SEO text block: hidden prose for Google, useful for users who want detail -->
    <section class="section bg-almond-pale/40">
      <div class="container">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12" data-reveal>
            <span class="badge">Why Spanish Almonds?</span>
            <h2 class="font-display text-4xl font-bold text-soil mb-4">
              Spanish almonds vs California:<br/>
              <span class="text-grad">what makes ours different</span>
            </h2>
          </div>
          <div class="grid md:grid-cols-2 gap-8 text-bark/80 leading-relaxed" data-reveal>
            <div class="space-y-4">
              <h3 class="font-display text-xl font-bold text-soil">Hard-shell, flavour-rich varieties</h3>
              <p>Unlike Californian almonds (soft-shell, large-volume), Spanish varieties like <strong class="text-soil">Solana</strong> and <strong class="text-soil">Lauranne</strong> have a hard, non-porous shell that acts as a natural barrier against pests and chemicals — so no post-harvest fumigation is required.</p>
              <p>Spanish almonds also have a <strong class="text-soil">higher oil content</strong>, giving them a richer, more complex flavour that patissiers, chocolatiers and fine-food retailers across Europe specifically seek out.</p>
            </div>
            <div class="space-y-4">
              <h3 class="font-display text-xl font-bold text-soil">Chandler: the world's #1 walnut variety</h3>
              <p>The <strong class="text-soil">Chandler walnut</strong> was developed at UC Davis and is now the most planted commercial walnut globally. Its key attributes — <strong class="text-soil">thin shell, extra-light kernel colour and mild buttery flavour with zero bitterness</strong> — make it the benchmark for premium European retail.</p>
              <p>Our Chandler walnuts are grown in Spain's ideal climate, hand-inspected for colour grade and packed fresh — giving you the quality that commands the highest market prices.</p>
            </div>
          </div>

          <!-- Quick comparison table -->
          <div class="mt-12 overflow-x-auto" data-reveal>
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-soil text-cream">
                  <th class="text-left px-5 py-3 rounded-tl-xl font-semibold text-xs uppercase tracking-wider">Feature</th>
                  <th class="px-5 py-3 font-semibold text-xs uppercase tracking-wider text-almond">Solana Nuts (ES)</th>
                  <th class="px-5 py-3 rounded-tr-xl font-semibold text-xs uppercase tracking-wider opacity-60">California (US)</th>
                </tr>
              </thead>
              <tbody>
                {[
                  ['Shell type',         'Hard, non-porous',         'Soft shell'],
                  ['Post-harvest fumigation', '❌ Not required',     '✅ Standard practice'],
                  ['Oil content',        'Higher (richer flavour)',   'Lower'],
                  ['Origin traceability','Single farm, GPS-level',   'Large co-ops'],
                  ['Price premium',      'Commands higher price ✓',  'Commodity pricing'],
                  ['Organic potential',  'Spain: #1 organic producer','Limited'],
                  ['EU food safety',     'Full EU compliance ✓',      'Import checks apply'],
                ].map(([feat, us, them], i) => (
                  <tr class={i % 2 === 0 ? 'bg-cream' : 'bg-sand/50'}>
                    <td class="px-5 py-3.5 font-semibold text-soil text-xs">{feat}</td>
                    <td class="px-5 py-3.5 text-center text-bark font-medium">{us}</td>
                    <td class="px-5 py-3.5 text-center text-stone">{them}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <About />
    <WhyUs />

    <!-- Testimonial / social proof -->
    <section class="section bg-cream">
      <div class="container">
        <div class="text-center max-w-xl mx-auto mb-12" data-reveal>
          <span class="badge">What buyers say</span>
          <h2 class="font-display text-4xl font-bold text-soil">Trusted by delis, bakers<br/>and importers across Europe</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { quote:"The Lauranne almonds are incredible — the skin stays perfectly intact even after baking. Our croissant sales have gone up since we switched supplier.", name:"Thomas B.", role:"Head Pâtissier, Munich", country:"🇩🇪" },
            { quote:"We tried the Chandler walnut sample and the colour grade was exceptional. Placed our first 200 kg order two weeks later. Arrived in perfect condition.", name:"Sophie M.", role:"Fine Foods Buyer, Lyon", country:"🇫🇷" },
            { quote:"What I love is talking to the actual family that grows the almonds. No broker, no middleman — just honest conversation and a great product.", name:"Marco R.", role:"Organic Deli Owner, Milan", country:"🇮🇹" },
          ].map((t, i) => (
            <div class="bg-white rounded-2xl p-7 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-1" data-reveal data-d={String(i+1)}>
              <div class="text-almond text-2xl mb-4">★★★★★</div>
              <blockquote class="font-display text-soil/90 italic text-base leading-relaxed mb-5">"{t.quote}"</blockquote>
              <div class="flex items-center gap-3 pt-4 border-t border-sand">
                <div class="w-10 h-10 rounded-full bg-sand flex items-center justify-center text-xl">{t.country}</div>
                <div>
                  <div class="font-bold text-soil text-sm">{t.name}</div>
                  <div class="text-stone text-xs">{t.role}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ / SEO section -->
    <section class="section bg-sand">
      <div class="container">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          <div data-reveal>
            <span class="badge">FAQ</span>
            <h2 class="font-display text-4xl font-bold text-soil mb-4">
              Frequently asked<br/><span class="text-grad">by European buyers</span>
            </h2>
            <p class="text-bark/75 mb-6">Can't find your answer? <a href="/contact" class="text-almond font-semibold underline hover:text-bark">Drop us a message</a> — we reply within 24 hours.</p>
            <a href="/contact" class="btn-primary">Request a Free Sample →</a>
          </div>
          <div class="space-y-3" data-reveal data-d="2">
            {[
              { q:'What is the minimum order quantity?', a:'We welcome orders from 5 kg upwards for retail/tasting purposes, with no MOQ for sample boxes. For wholesale pricing, orders of 25 kg+ qualify. We also handle full pallets (800–1000 kg) and container loads for distributors.' },
              { q:'Do you ship to my country?', a:'We ship to all EU countries, the UK, Switzerland, Norway and many non-EU destinations. Shipping is typically DDP (Delivered Duty Paid) or FCA Spain — we\'ll discuss the best Incoterm for your order.' },
              { q:'Can I get a free sample before ordering?', a:'Yes! We offer free sample boxes (up to 500g per variety) for qualified buyers. Fill out the contact form and select "Free Sample" — we\'ll dispatch within 3 working days.' },
              { q:'What certifications do you have?', a:'We hold EU food safety certification under Regulation 178/2002. All batches are tested for mycotoxins (aflatoxin), pesticide residues and allergens. Full documentation provided with every shipment.' },
              { q:'Are your almonds organic?', a:'Our conventional crop is grown with minimal inputs and no post-harvest fumigation. Organic-certified production is available seasonally — ask us for current availability.' },
              { q:'What formats are available?', a:'Raw whole (in-shell or shelled), blanched, roasted, sliced, slivered, diced and ground almond flour. Chandler walnuts available as in-shell, shelled halves and broken pieces. Custom processing available for large orders.' },
            ].map(faq => (
              <details class="group bg-white rounded-2xl overflow-hidden shadow-card border border-sand">
                <summary class="flex items-center justify-between px-6 py-4.5 cursor-pointer text-sm font-semibold text-soil list-none hover:bg-sand/40 transition-colors">
                  {faq.q}
                  <span class="text-almond text-lg font-bold transition-transform group-open:rotate-45 flex-shrink-0 ml-3">+</span>
                </summary>
                <div class="px-6 pb-5 text-sm text-bark/75 leading-relaxed border-t border-sand/60 pt-4">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Schema.org FAQ for SEO -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type":"Question","name":"What is the minimum order for Spanish almonds?","acceptedAnswer":{"@type":"Answer","text":"We welcome orders from 5 kg upwards. Sample boxes are free for qualified buyers. Full pallets and container loads available for distributors."}},
        { "@type":"Question","name":"Do you ship almonds to Germany, France, Italy and the UK?","acceptedAnswer":{"@type":"Answer","text":"Yes. We ship DDP or FCA to all EU countries, the UK, Switzerland and many other destinations. Most orders arrive within 3-5 working days."}},
        { "@type":"Question","name":"What is the difference between Solana, Lauranne and Marcona almonds?","acceptedAnswer":{"@type":"Answer","text":"Solana is a round, sweet Spanish variety. Lauranne is a larger, elongated French-Spanish cross prized for its intact skin when baked. Marcona is the famous round Spanish variety used in nougat. All have higher oil content than Californian almonds."}}
      ]
    }
    </script>

    <Contact />
  </main>
  <Footer />
</Base>
