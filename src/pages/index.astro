---
import Base          from '../layouts/Base.astro';
import Nav           from '../components/Nav.astro';
import Hero          from '../components/Hero.astro';
import Marquee       from '../components/Marquee.astro';
import Filosofia     from '../components/Filosofia.astro';
import Productos     from '../components/Productos.astro';
import Sostenibilidad from '../components/Sostenibilidad.astro';
import Testimonios   from '../components/Testimonios.astro';
import FAQ           from '../components/FAQ.astro';
import Contacto      from '../components/Contacto.astro';
import Footer        from '../components/Footer.astro';

const title       = 'Solana Nuts · Almendras y nueces naturales del Bajo Aragón | Directo del productor';
const description = 'Comprar almendras y nueces naturales del Bajo Aragón directamente del productor. Almendra Soleta, Lauranne y Nuez Chandler cultivadas en Fayón (Zaragoza). Cosecha a mano, secado al aire, envase reutilizable. Envío a toda España y Europa.';
const keywords    = 'comprar almendras online, almendras naturales, almendra soleta, almendra lauranne, nuez chandler, frutos secos del productor, almendras bajo aragón, almendras fayón, almendras con cáscara, nueces naturales, frutos secos ecológicos, agricultura familiar aragón, almendras sin intermediarios, almendras 5 kg';

const productSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "@id": "https://solananuts.com/variedades/almendra-soleta#soleta-1kg",
      "name": "Almendra Soleta con cáscara 1 kg",
      "description": "Almendra Soleta cultivada en Fayón (Bajo Aragón). Cosecha a mano y secado natural al aire. Variedad aragonesa del CITA Zaragoza, pepita elíptica de sabor dulce.",
      "image": ["https://solananuts.com/og-default.jpg"],
      "brand": { "@type": "Brand", "name": "Solana Nuts" },
      "category": "Frutos secos > Almendras con cáscara",
      "countryOfOrigin": "ES",
      "material": "Almendra Soleta",
      "weight": { "@type": "QuantitativeValue", "value": 1, "unitCode": "KGM" },
      "offers": {
        "@type": "Offer",
        "price": "5.90",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://solananuts.com/variedades/almendra-soleta",
        "priceValidUntil": "2026-12-31",
        "itemCondition": "https://schema.org/NewCondition",
        "seller": { "@type": "Organization", "name": "Solana Nuts" },
        "shippingDetails": {
          "@type": "OfferShippingDetails",
          "shippingRate": { "@type": "MonetaryAmount", "value": "4.90", "currency": "EUR" },
          "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "ES" },
          "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 1, "maxValue": 2, "unitCode": "DAY" }, "transitTime": { "@type": "QuantitativeValue", "minValue": 2, "maxValue": 4, "unitCode": "DAY" } }
        }
      },
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "127", "bestRating": "5" }
    },
    {
      "@type": "Product",
      "@id": "https://solananuts.com/variedades/almendra-soleta#soleta-5kg",
      "name": "Almendra Soleta con cáscara 5 kg",
      "description": "Formato familiar 5 kg de Almendra Soleta en bolsa reutilizable de algodón y kraft.",
      "image": ["https://solananuts.com/og-default.jpg"],
      "brand": { "@type": "Brand", "name": "Solana Nuts" },
      "category": "Frutos secos > Almendras con cáscara",
      "countryOfOrigin": "ES",
      "weight": { "@type": "QuantitativeValue", "value": 5, "unitCode": "KGM" },
      "offers": {
        "@type": "Offer",
        "price": "24.90",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://solananuts.com/variedades/almendra-soleta",
        "priceValidUntil": "2026-12-31",
        "itemCondition": "https://schema.org/NewCondition",
        "seller": { "@type": "Organization", "name": "Solana Nuts" }
      },
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "84", "bestRating": "5" }
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type":"Question", "name":"¿Cuándo es la cosecha y en qué fechas recibiré mis almendras?", "acceptedAnswer":{ "@type":"Answer", "text":"La cosecha de almendra se realiza entre finales de agosto y principios de octubre. La de nuez Chandler entre octubre y noviembre. Tras el secado natural, los envíos comienzan en noviembre." } },
    { "@type":"Question", "name":"¿Las almendras son ecológicas o naturales?", "acceptedAnswer":{ "@type":"Answer", "text":"Producción 100% natural, sin fumigación post-cosecha ni aditivos. Certificación ecológica en trámite." } },
    { "@type":"Question", "name":"¿A qué países enviáis y cuánto cuesta el envío?", "acceptedAnswer":{ "@type":"Answer", "text":"Enviamos a toda España peninsular, Baleares y Europa (Francia, Alemania, Italia, Portugal, Reino Unido, Países Bajos…). Envío gratis a Península desde 45 €." } },
    { "@type":"Question", "name":"¿Qué diferencia hay entre Almendra Soleta y Almendra Lauranne?", "acceptedAnswer":{ "@type":"Answer", "text":"Soleta es una variedad aragonesa del CITA Zaragoza con pepita elíptica y sabor dulce. Lauranne es más alargada, con corazón marrón claro y piel que se mantiene al hornear." } },
    { "@type":"Question", "name":"¿Cómo conservar las almendras y nueces con cáscara?", "acceptedAnswer":{ "@type":"Answer", "text":"En lugar fresco, seco y oscuro, en su bolsa de algodón original. Aguantan más de 12 meses con cáscara." } },
    { "@type":"Question", "name":"¿Hacéis pedidos al por mayor o a hostelería?", "acceptedAnswer":{ "@type":"Answer", "text":"Sí. Desde 25 kg aplicamos precio mayorista, y pallet completo (800–1000 kg) con condiciones especiales." } }
  ]
};

const combinedSchema = { "@context": "https://schema.org", "@graph": [productSchema, faqSchema] };
---
<Base title={title} description={description} keywords={keywords} canonical="https://solananuts.com/" schema={combinedSchema}>
  <Nav />
  <main id="contenido">
    <Hero />
    <Marquee />
    <Filosofia />
    <Productos />

    <!-- SEO rich text: Spanish vs otros orígenes + tabla comparativa -->
    <section class="section bg-almendra-pale/45" aria-labelledby="comparativa-heading">
      <div class="container">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12" data-reveal>
            <span class="badge">¿Por qué almendra del Bajo Aragón?</span>
            <h2 id="comparativa-heading" class="font-display text-4xl md:text-5xl font-bold text-tierra mb-5 leading-[1.1]">
              Almendra española <span class="text-grad">vs. almendra californiana</span>: por qué sabe distinto
            </h2>
            <p class="text-corteza/80 text-lg">La diferencia no es marketing: es agronomía.</p>
          </div>

          <div class="grid md:grid-cols-2 gap-8 text-corteza/85 leading-relaxed mb-10" data-reveal>
            <div class="space-y-4">
              <h3 class="font-display text-xl font-bold text-tierra">Cáscara dura y sabor intenso</h3>
              <p>A diferencia de la almendra californiana (cáscara blanda, producción a gran escala), las variedades españolas como <strong>Soleta</strong>, <strong>Lauranne</strong> y Marcona tienen <strong>cáscara dura y no porosa</strong>. Esa cáscara actúa como barrera natural contra plagas — por eso no se fumiga tras la cosecha.</p>
              <p>Además, la almendra española tiene <strong>mayor contenido en aceites naturales</strong>, lo que le da un sabor más intenso y complejo que buscan pastelerías, turroneros y tiendas gourmet de toda Europa.</p>
            </div>
            <div class="space-y-4">
              <h3 class="font-display text-xl font-bold text-tierra">Chandler: la nuez nº 1 del mundo</h3>
              <p>La <strong>Nuez Chandler</strong> fue desarrollada en la Universidad de California-Davis y hoy es la variedad más plantada a nivel mundial. Sus señas: <strong>cáscara fina, gallo extra claro y sabor suave sin amargor</strong>.</p>
              <p>Nuestra Chandler crece en el clima continental del Bajo Aragón — el mismo que le da a la fruta de hueso aragonesa su fama. Rendimiento 45–50 % y color extra claro que se paga a precio premium.</p>
            </div>
          </div>

          <div class="overflow-x-auto" data-reveal>
            <table class="w-full text-sm border-collapse rounded-2xl overflow-hidden shadow-warm">
              <caption class="sr-only">Comparativa entre almendra española (Solana Nuts) y almendra californiana</caption>
              <thead>
                <tr class="bg-tierra text-crema">
                  <th scope="col" class="text-left px-5 py-3.5 font-semibold text-xs uppercase tracking-wider">Característica</th>
                  <th scope="col" class="px-5 py-3.5 font-semibold text-xs uppercase tracking-wider text-almendra-light">Solana Nuts (ES)</th>
                  <th scope="col" class="px-5 py-3.5 font-semibold text-xs uppercase tracking-wider opacity-60">California (US)</th>
                </tr>
              </thead>
              <tbody>
                {[
                  ['Tipo de cáscara',         'Dura, no porosa',            'Blanda'],
                  ['Fumigación post-cosecha', '❌ No necesaria',             '✅ Estándar'],
                  ['Contenido en aceite',     'Alto (sabor más intenso)',    'Bajo'],
                  ['Trazabilidad origen',     'Finca única, con GPS',       'Grandes cooperativas'],
                  ['Secado',                  'Natural al sol y al aire',    'Mecánico industrial'],
                  ['Envase',                  'Algodón + kraft reutilizable','Plástico'],
                  ['Huella de transporte',    'Fayón → tu casa',             '8.000 km + barco'],
                ].map(([feat, us, them], i) => (
                  <tr class={i % 2 === 0 ? 'bg-crema' : 'bg-arena/60'}>
                    <th scope="row" class="px-5 py-3.5 font-semibold text-tierra text-xs text-left">{feat}</th>
                    <td class="px-5 py-3.5 text-center text-corteza font-medium">{us}</td>
                    <td class="px-5 py-3.5 text-center text-piedra">{them}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="mt-10 text-center" data-reveal>
            <a href="/blog/almendra-espanola-vs-californiana" class="btn btn-ghost">
              Leer la guía completa →
            </a>
          </div>
        </div>
      </div>
    </section>

    <Sostenibilidad />
    <Testimonios />

    <!-- SEO pillar content block: Bajo Aragón -->
    <section class="section bg-crema" aria-labelledby="aragon-heading">
      <div class="container">
        <div class="grid lg:grid-cols-[1fr_1.15fr] gap-14 items-center">
          <div class="relative aspect-square rounded-[32px] bg-gradient-to-br from-sol via-almendra to-corteza shadow-warm-lg overflow-hidden grano" data-reveal>
            <div class="absolute inset-x-0 bottom-0 p-8 bg-gradient-to-t from-tierra/70 to-transparent">
              <div class="font-display text-crema text-3xl font-bold">Bajo Aragón</div>
              <div class="text-crema/85 text-sm mt-1">Fayón, Zaragoza — 41.24°N, 0.34°E</div>
            </div>
            <div class="absolute top-6 left-6 bg-crema/90 backdrop-blur rounded-2xl px-4 py-3">
              <div class="text-[10px] font-bold uppercase tracking-[.18em] text-almendra">Altitud</div>
              <div class="font-display text-tierra text-lg font-bold">112 m</div>
            </div>
            <div class="absolute top-6 right-6 bg-crema/90 backdrop-blur rounded-2xl px-4 py-3">
              <div class="text-[10px] font-bold uppercase tracking-[.18em] text-almendra">Clima</div>
              <div class="font-display text-tierra text-lg font-bold">Continental</div>
            </div>
          </div>
          <div data-reveal data-d="2">
            <span class="kicker">Nuestro terruño</span>
            <h2 id="aragon-heading" class="font-display text-4xl md:text-5xl font-bold text-tierra mb-5 leading-[1.1]">
              Por qué el <span class="text-grad">Bajo Aragón</span> hace mejores almendras
            </h2>
            <p class="text-corteza/85 text-lg leading-relaxed mb-4">
              El Bajo Aragón es uno de los tres grandes terruños almendreros de España —junto a Levante y Andalucía—.
              Aquí la combinación de <strong>sol intenso, noches frescas, suelo calizo y viento cierzo</strong> da una
              pepita con más densidad de aceites, menos humedad y un aroma que no se consigue en cultivos intensivos.
            </p>
            <ul class="space-y-3 mb-7 text-corteza/85">
              <li class="flex items-start gap-3"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-almendra flex-shrink-0"></span><span><strong class="text-tierra">+300 días de sol al año</strong> para un secado natural lento y completo.</span></li>
              <li class="flex items-start gap-3"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-almendra flex-shrink-0"></span><span><strong class="text-tierra">Contraste térmico día-noche</strong> que concentra azúcares y aromas en la pepita.</span></li>
              <li class="flex items-start gap-3"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-almendra flex-shrink-0"></span><span><strong class="text-tierra">Suelos calizos y agua del Ebro</strong> — la DOP original del aceite y la fruta aragonesa.</span></li>
              <li class="flex items-start gap-3"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-almendra flex-shrink-0"></span><span><strong class="text-tierra">Secano tradicional</strong>: árboles que dan menos fruto, pero con muchísima más densidad de sabor.</span></li>
            </ul>
            <a href="/la-finca" class="btn btn-primary">Conocer la finca →</a>
          </div>
        </div>
      </div>
    </section>

    <FAQ />
    <Contacto />
  </main>
  <Footer />
</Base>
