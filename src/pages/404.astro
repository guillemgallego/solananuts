---
import Base   from '../layouts/Base.astro';
import Nav    from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Página no encontrada · Solana Nuts"
  description="Esta página no existe o ha sido movida. Vuelve a la tienda de almendras y nueces del Bajo Aragón."
  noindex={true}
>
  <Nav />
  <main id="contenido" class="min-h-[70vh] flex items-center py-24">
    <div class="container text-center max-w-xl">
      <div class="text-7xl mb-6" aria-hidden="true">🌰</div>
      <h1 class="font-display text-5xl md:text-6xl font-bold text-tierra mb-4 leading-tight">
        Esta página<br/><span class="italic text-almendra">se cayó del árbol</span>
      </h1>
      <p class="text-corteza/70 text-lg mb-10 leading-relaxed">
        La URL que buscas no existe o ha sido movida. No pasa nada — vuelve a la finca.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/" class="btn btn-primary">Ir al inicio →</a>
        <a href="/productos" class="btn btn-outline">Ver productos</a>
        <a href="/contacto" class="btn btn-ghost">Contactar</a>
      </div>
      <div class="mt-12 pt-8 border-t border-arena text-sm text-piedra">
        <p>¿Buscabas algo concreto?</p>
        <div class="flex flex-wrap gap-3 justify-center mt-4">
          <a href="/variedades/almendra-soleta" class="text-almendra hover:underline">Almendra Soleta</a>
          <span aria-hidden="true">·</span>
          <a href="/variedades/almendra-lauranne" class="text-almendra hover:underline">Almendra Lauranne</a>
          <span aria-hidden="true">·</span>
          <a href="/variedades/nuez-chandler" class="text-almendra hover:underline">Nuez Chandler</a>
          <span aria-hidden="true">·</span>
          <a href="/blog" class="text-almendra hover:underline">Blog</a>
          <span aria-hidden="true">·</span>
          <a href="/preguntas-frecuentes" class="text-almendra hover:underline">FAQ</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
