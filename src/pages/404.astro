---
import Base   from '../layouts/Base.astro';
import Nav    from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Page Not Found | Solana Nuts" description="Page not found." noindex={true}>
  <Nav/>
  <main class="min-h-[65vh] flex items-center justify-content:center text-center py-24">
    <div class="container">
      <div class="text-7xl mb-4">🌰</div>
      <h1 class="font-display text-5xl font-bold text-soil mb-3">Page not found</h1>
      <p class="text-bark/70 text-lg mb-8 max-w-md mx-auto">This page seems to have fallen off the tree. Let's get you back on track.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="btn-primary">Go to homepage</a>
        <a href="/contact" class="btn-outline">Contact us</a>
      </div>
    </div>
  </main>
  <Footer/>
</Base>
